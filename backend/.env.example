# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/jobdb

# Frontend URL for CORS (use * to allow all origins in dev)
FRONTEND_URL=http://localhost:3000

# Anthropic API key — used for resume tailoring
ANTHROPIC_API_KEY=sk-ant-...

# RapidAPI key — used for JSearch job listings (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
RAPIDAPI_KEY=your-rapidapi-key-here

# Server port (default: 3001)
PORT=3001
